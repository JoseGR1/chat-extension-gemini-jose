{
  "manifest_version": 3,
  "name": "Gemini Navigator",
  "version": "1.0.0",
  "description": "Una extensión premium para navegar conversaciones largas en Gemini web.",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*"
      ],
      "js": [
        "src/content/storage.js",
        "src/content/platform/gemini.js",
        "src/content/dom.js",
        "src/content/navigation.js",
        "src/content/ui.js",
        "src/content/main.js"
      ],
      "css": [
        "styles/content.css"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
